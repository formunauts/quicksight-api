# Database connection settings
DB_HOST=
DB_PORT=
DB_USER=
DB_NAME=
DB_PASS=
LOCAL_PORT=

# QuickSight settings
# Comma-separated list of QuickSight user ARNs to share the dashboard with
QS_TARGET_USERS=arn:aws:quicksight:...
# QuickSight resource identifiers
QS_AWS_ACCOUNT_ID=
QS_AWS_REGION=
QS_DATASOURCE_ID= # Data source ID in QuickSight
CLUSTER_ID= # RDS cluster ID
QS_SECURITY_GROUP_ID= # Security group ID for QuickSight VPC connection
QS_PROD_CIDR= # CIDR block for QuickSight access
VPC_CONN_ID= # VPC connection ID in QuickSight
VPC_CONN_ARN=arn: # VPC connection ARN in QuickSight